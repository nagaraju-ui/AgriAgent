# Choose the reasoning backend: auto | openai | ollama | none
LLM_PROVIDER=auto
# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Ollama local model (optional; you have Ollama installed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
# data.gov.in / Agmarknet mandi prices (optional; sample data used if blank)
AGMARKNET_API_KEY=
# Output language: en | te
OUTPUT_LANG=en
DEFAULT_LOCATION=Vijayawada
MAX_STEPS=8
